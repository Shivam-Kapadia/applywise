# Copy to .env and fill in. Do NOT commit your real .env.

# Database connection.
#   Local (default):   file:./dev.db        (SQLite)
#   Deployed (Neon):   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="file:./dev.db"

# Optional single-password lock. Leave UNSET to keep the app open (fine for
# local use). Set it on the deployed site so only you can get in.
# APP_PASSWORD="choose-a-strong-password"
